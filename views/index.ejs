<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>SpecialtyFlow - Barista Pro</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body {
        
            background: url('https://images.unsplash.com/photo-1497935586351-b67a49e012bf?q=80&w=1920') no-repeat center center fixed;
            background-size: cover;
        }
        .card {
            background-color: rgba(255, 255, 255, 0.95) !important;
        }
        .titulo-caja {
            background-color: rgba(44, 43, 43, 0.7);
            border-radius: 10px;
            padding: 20px;
            color: white !important;
        }
    </style>
</head>
<body class="bg-light">

<div class="container mt-5">
    
    <div class="text-center mb-4 titulo-caja">
        <h1 class="display-4 text-white">☕ SpecialtyFlow</h1>
        <p class="lead text-white"><%= mensaje %></p>
    </div>

    <div class="row">
        
        <div class="col-md-4">
            <div class="card shadow-sm">
                <div class="card-header bg-dark text-white">
                    <h5 class="mb-0">Registrar Nuevo Café</h5>
                </div>
                <div class="card-body">
                    <form action="/cafes" method="POST">
                        <div class="mb-3">
                            <label class="form-label">Origen:</label>
                            <input type="text" class="form-control" name="origen" placeholder="Ej: Etiopía" required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Nivel de Tueste:</label>
                            <select class="form-select" name="nivel_tueste">
                                <option value="Claro">Claro</option>
                                <option value="Medio">Medio</option>
                                <option value="Oscuro">Oscuro</option>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Precio por Kg ($):</label>
                            <input type="number" step="0.01" class="form-control" name="precio_por_kg" placeholder="0.00" required>
                        </div>
                        <button type="submit" class="btn btn-success w-100">Guardar en Inventario</button>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-md-8">
            <div class="card shadow-sm">
                <div class="card-header bg-dark text-white">
                    <h5 class="mb-0">Nuestro Inventario de Granos</h5>
                </div>
                <div class="card-body">
                    
                    <form action="/" method="GET" class="row g-2 mb-3">
                        <div class="col-md-5">
                            <input type="text" name="busqueda" class="form-control" placeholder="🔍 Buscar origen (Ej: Colombia)">
                        </div>
                        <div class="col-md-3">
                            <select name="tueste" class="form-select">
                                <option value="Todos">Cualquier Tueste</option>
                                <option value="Claro">Claro</option>
                                <option value="Medio">Medio</option>
                                <option value="Oscuro">Oscuro</option>
                            </select>
                        </div>
                        <div class="col-md-3">
                            <select name="ordenPrecio" class="form-select">
                                <option value="none">Ordenar Precio...</option>
                                <option value="asc">Menor a Mayor ⬆️</option>
                                <option value="desc">Mayor a Menor ⬇️</option>
                            </select>
                        </div>
                        <div class="col-md-1">
                            <button type="submit" class="btn btn-secondary w-100">Ir</button>
                        </div>
                    </form>
                    <table class="table table-hover align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>Origen</th>
                                <th>Tueste</th>
                                <th>Precio ($)</th>
                                <th>Acción</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% cafes.forEach(cafe => { %>
                                <tr>
                                    <td><strong><%= cafe.origen %></strong></td>
                                    <td><span class="badge bg-info text-dark"><%= cafe.nivel_tueste %></span></td>
                                    <td>$<%= cafe.precio_por_kg %></td>
                                    <td>
                                        <form action="/cafes/borrar/<%= cafe.id %>" method="POST" class="d-inline">
                                            <button type="submit" class="btn btn-sm btn-danger">Eliminar</button>
                                        </form>
                                    </td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

</body>
</html>