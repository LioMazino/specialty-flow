<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>SpecialtyFlow - Barista Pro</title>
</head>
<body>
    <h1><%= mensaje %></h1>

    <h2>Nuestro Inventario de Granos:</h2>
    
    <ul>
        <% cafes.forEach(cafe => { %>

            <li> <%= cafe.origen %> - Tueste: <%= cafe.nivel_tueste %> </li>

        <% }) %>
    </ul>
<hr>
    <h2>Registrar Nuevo Café:</h2>
    <form action="/cafes" method="POST">
        <label>Origen:</label>
        <input type="text" name="origen" required> <br><br>

        <label>Nivel de Tueste:</label>
        <select name="nivel_tueste">
            <option value="Claro">Claro</option>
            <option value="Medio">Medio</option>
            <option value="Oscuro">Oscuro</option>
        </select> <br><br>

        <label>Precio por Kg ($):</label>
        <input type="number" step="0.01" name="precio_por_kg" required> <br><br>

        <button type="submit">Guardar Café en Inventario</button>
    </form>
</body>
</html>